# openEBM backend environment variables
# Copy to .env locally; on Render set these in the dashboard.
# NEVER commit real values.

APP_ENV=development
APP_NAME=openEBM

# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
CLAUDE_MODEL=claude-opus-4-5
CLAUDE_FAST_MODEL=claude-sonnet-4-5

# PostgreSQL on Render — set this via Render dashboard env vars only.
# Example: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@host:5432/openebm

# CORS — comma separated
ALLOWED_ORIGINS=http://localhost:3000,https://openebm.vercel.app

# Optional
REDIS_URL=
VERIFY_TIMEOUT_SECONDS=8
MAX_CONCURRENT_VERIFICATIONS=10
